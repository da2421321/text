{
  "name": "ecommerce-admin-api",
  "version": "1.0.0",
  "description": "TypeScript 电商后台管理系统",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
  "keywords": ["typescript", "koa", "typeorm", "mysql", "ecommerce"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "koa": "^2.14.2",
    "koa-body": "^6.0.1",
    "koa-router": "^12.0.0",
    "koa-cors": "^0.0.16",
    "typeorm": "^0.3.17",
    "mysql2": "^3.6.0",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "multer": "^1.4.5-lts.1",
    "@koa/multer": "^3.0.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/koa": "^2.13.9",
    "@types/koa-router": "^7.4.4",
    "@types/koa-cors": "^0.0.2",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/multer": "^1.4.8",
    "@types/node": "^20.6.0",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1"
  }
}

