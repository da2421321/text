APP_ENV=development
APP_NAME=chamber-backend
APP_PORT=8080

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_USER=chamber
MYSQL_PASSWORD=change-me-db-password
MYSQL_DSN=chamber:change-me-db-password@tcp(mysql:3306)/chamber?charset=utf8mb4&parseTime=True&loc=Local

JWT_SECRET=replace-with-a-strong-secret-at-least-32-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
TOKEN_EXPIRES_IN=7200
